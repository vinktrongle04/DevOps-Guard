#!/usr/bin/env sh

# ============================================================
# DevOps-Guard — Husky Pre-Commit Hook
# Pipeline order: Gate 6 (Policy) → Gate 1 (Security) → Gate 2 (Dependency)
# ============================================================

echo ""
echo "  DevOps-Guard Pre-Commit Pipeline starting..."
echo ""

# ─── GATE 6: Policy Integrity Guard ──────────────────────────
echo "  [Gate 6] Policy Integrity Check..."
node policy-guard.js
GATE6_EXIT=$?

if [ $GATE6_EXIT -ne 0 ]; then
  echo ""
  echo "  POLICY GUARD BLOCKED — Agent brain file integrity check failed."
  echo ""
  exit 1
fi

# ─── GATE 1: Security Scanner (HARD BLOCK) ───────────────────
echo "  [Gate 1] Security Scanner..."
node security-scanner.js
GATE1_EXIT=$?

if [ $GATE1_EXIT -ne 0 ]; then
  echo ""
  echo "  GATE 1 BLOCKED — Commit rejected by Security Scanner."
  echo "  Remove all secrets before committing."
  echo ""
  exit 1
fi

echo "  Gate 1 passed."
echo ""

# ─── GATE 2: Dependency Scanner (SOFT BLOCK) ─────────────────
echo "  [Gate 2] Dependency Scanner..."
node dependency-scanner.js
GATE2_EXIT=$?

if [ $GATE2_EXIT -ne 0 ]; then
  echo ""
  echo "  GATE 2 BLOCKED — Commit rejected by Dependency Scanner."
  echo "  Fix missing dependencies before committing."
  echo ""
  exit 1
fi

echo "  Gate 2 passed."
echo ""

# ─── ALL GATES PASSED ────────────────────────────────────────
echo "  All Quality Gates passed. Commit is allowed."
echo ""
