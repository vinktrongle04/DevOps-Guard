# DevOps-Guard Environment Configuration
# Copy this file to .env and fill in the required values

# ─── KNOWLEDGE BASE ──────────
# Optional: Set a custom path for the knowledge base directory
# DEVOPS_GUARD_KB_PATH=./.knowledge-base

# ─── AI ORCHESTRATION ────────
# Required if using AI integrations for security auto-fixes
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── DASHBOARD ───────────────
# Optional: Configure the UI dashboard
PORT=5173
VITE_API_URL=http://localhost:5173/api