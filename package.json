{
  "name": "devops-guard-demo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Mock React 18 project with intentional issues for DevOps-Guard demo",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "security:scan": "node security-scanner.js",
    "security:json": "node security-scanner.js --json",
    "security:sarif": "node security-scanner.js --sarif",
    "dep:scan": "node dependency-scanner.js",
    "scan:export": "node scanner-output.js",
    "gate:all": "node security-scanner.js; node dependency-scanner.js",
    "fix:dry": "node security-autofix.js",
    "fix:apply": "node security-autofix.js --apply",
    "fix:src": "node security-autofix.js --apply --src src/",
    "prepare": "husky",
    "kb:build": "node scanner-output.js",
    "kb:summary": "node kb-summary.js",
    "graph:build": "node graph-builder.js",
    "graph:query": "node graph-query.js",
    "kb:ask": "node graph-query.js --ask",
    "knowledge:update": "node scanner-output.js && node graph-builder.js && node kb-summary.js",
    "snapshot": "node snapshot-generator.js",
    "scan-and-snapshot": "npm run scan:export && npm run snapshot"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lodash": "^4.17.21",
    "axios": "^1.7.9",
    "moment": "^2.30.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "vite": "^6.0.0"
  }
}
